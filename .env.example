# Copy to .env.local for local dev, or set these in Vercel Project Settings
# (Settings -> Environment Variables), then redeploy.

# Supabase — stores raters and their responses (durable across requests).
# Find these in your Supabase project: Settings -> API.
#   SUPABASE_URL              = Project URL  (https://<ref>.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY = the "service_role" secret (NOT the anon key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# A long random string you choose. Protects /api/export (the CSV download).
ADMIN_TOKEN=change-me-to-a-long-random-string

# Optional: secret used by scripts/prepare_images.mjs for filename hashing.
# (only needed at image-prep time, not at runtime)
SECRET=change-me-too
